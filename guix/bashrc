[ -f "$HOME"/.nix-profile/etc/profile.d/hm-session-vars.sh ] && source "$HOME"/.nix-profile/etc/profile.d/hm-session-vars.sh

case $- in
  *i*) ;;
    *) return;;
esac

source ~/.local/share/blesh/ble.sh --noattach

export OSH='/home/worldofgeese/.oh-my-bash'
OSH_THEME="font"
OMB_USE_SUDO=true
completions=(
  git
  ssh
  helm
  kubectl
)
aliases=(
  general
)
plugins=(
  git
  bashmarks
  kubectl
  bu
  battery
  sudo
  colored-man-pages
)
source "$OSH"/oh-my-bash.sh
unalias gc 2>/dev/null

export _ZO_DOCTOR=0
export GPG_TTY=$(tty)
gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
export MPS_API_KEY=$(gopass show -o dev/anthropic-proxy-key 2>/dev/null)

# atuin and direnv shell integration managed by Nix Home Manager
# (programs.atuin and programs.direnv inject into bashrc via HM)
eval "$(podman completion bash)"

# ble.sh integrations (loaded deferred for fast startup)
ble-import -d integration/fzf-completion
ble-import -d integration/zoxide
ble-import contrib/prompt-git
ble-import -d contrib/prompt-elapsed
ble-import -d contrib/config/execmark

bleopt prompt_rps1='\q{contrib/git-info}'
bleopt exec_elapsed_enabled='_ble_exec_time_tot>=3000'

[[ ${BLE_VERSION-} ]] && ble-attach
